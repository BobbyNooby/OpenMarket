# Database
DATABASE_URL="postgresql://openmarket:openmarket@localhost:5432/openmarket"

# Auth (better-auth)
BETTER_AUTH_SECRET="generate_a_secure_random_string_here"
BETTER_AUTH_URL="http://localhost:3000"

# Discord OAuth (https://discord.com/developers/applications)
DISCORD_CLIENT_ID="your_discord_client_id"
DISCORD_CLIENT_SECRET="your_discord_client_secret"

# API
PUBLIC_API_URL="http://localhost:3000"
API_PORT=3000

# CORS (comma-separated origins, defaults to localhost if not set)
# CORS_ORIGINS=https://yoursite.com,https://www.yoursite.com
