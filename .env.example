# Database
DATABASE_URL="postgres://dev:dev@localhost:5432/openmarket"

# Redis
REDIS_URL="redis://localhost:6379"

# Auth (better-auth)
BETTER_AUTH_SECRET="generate_a_secure_random_string_here"

# Discord OAuth
DISCORD_CLIENT_ID="your_discord_client_id"
DISCORD_CLIENT_SECRET="your_discord_client_secret"
DISCORD_BOT_TOKEN="your_discord_bot_token"

# API
PUBLIC_API_URL="http://localhost:3000"
API_MASTER_KEY="generate_a_secure_random_string_here" # for securing internal API requests between frontend and backend

# Server
API_PORT=3000
NODE_ENV=development
