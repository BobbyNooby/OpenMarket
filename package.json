{
  "name": "openmarket",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@10.22.0",
  "type": "module",
  "scripts": {
    "check-env": "node scripts/check-env.js",
    "dev": "turbo run dev",
    "dev:server": "pnpm --filter @openmarket/server dev",
    "dev:frontend": "pnpm --filter @openmarket/frontend dev",
    "build": "pnpm run -r build",
    "check": "pnpm run -r check",
    "setup": "pnpm install && pnpm docker:dev"
  },
  "devDependencies": {
    "turbo": "^2",
    "typescript": "^5.0.0"
  }
}
