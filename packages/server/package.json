{
  "name": "@openmarket/server",
  "version": "0.0.1",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run --env-file=../../.env --watch src/index.ts",
    "build": "bun build src/index.ts --outdir=dist --target=bun",
    "start": "bun run --env-file=../../.env dist/index.js",
    "db:generate": "bun --env-file=../../.env drizzle-kit generate",
    "db:push": "bun --env-file=../../.env drizzle-kit push",
    "db:studio": "bun --env-file=../../.env drizzle-kit studio",
    "db:seed:rbac": "bun --env-file=../../.env src/db/rbac-seed.ts"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.0",
    "@openmarket/lib": "workspace:*",
    "better-auth": "^1.4.15",
    "drizzle-orm": "^0.44.0",
    "elysia": "^1.4.18",
    "postgres": "^3.4.5",
    "satori": "^0.26.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "bun-types": "latest",
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.0.0"
  }
}
