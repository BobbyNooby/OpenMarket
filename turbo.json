{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "//#check-env": {
      "cache": false
    },
    "dev": {
      "dependsOn": ["//#check-env"],
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "build/**"]
    },
    "check": {
      "dependsOn": ["^build"]
    }
  }
}
